APP_NAME=LearningManagement
MONGODB_URI=
MONGODB_DB=LearningManagement
MONGODB_TIMEOUT_MS=10000
MONGODB_CONNECT_ATTEMPTS=5
MONGODB_RETRY_DELAY_SECONDS=2
OPENAI_API_KEY=
SECRET_KEY=change-this-secret
JWT_SECRET_KEY=change-this-jwt-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Deployment CORS
# Use "*" to accept requests from Render, Vercel, local dev, and any other origin.
# If you want to lock it later, use comma-separated origins:
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=*
ALLOWED_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=false

# System admin created by backend startup.
DEFAULT_ADMIN_EMAIL=admin@eduai.edu
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DEFAULT_ADMIN_NAME=Platform Admin

# Keep false for clean production data.
SEED_DEMO_DATA=false
DEFAULT_API_PORT=8000
